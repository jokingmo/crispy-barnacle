/**pages/about/about.wxss**/
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 30rpx 20rpx;
}

.header {
  margin: 30rpx 0;
}

.icon {
  font-size: 100rpx;
}

.content {
  width: 100%;
  max-width: 700rpx;
}

.card {
  display: flex;
  flex-direction: column;
  background-color: white;
  padding: 20rpx;
  margin-bottom: 15rpx;
  border-radius: 8rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.card-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.features {
  background-color: white;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-top: 20rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.features-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.feature-item {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 0;
  line-height: 1.5;
}

.footer {
  text-align: center;
  margin-top: 40rpx;
  font-size: 26rpx;
  color: #999;
}